# Final stage - uses pre-built binary from GitHub Actions
FROM alpine:3.19

RUN apk update && \
    apk add --no-cache ca-certificates tzdata && \
    rm -rf /var/cache/apk/*

WORKDIR /app

COPY datapipe-worker .

RUN addgroup -g 1001 -S datapipe && \
    adduser -u 1001 -S datapipe -G datapipe

USER datapipe

EXPOSE 9090

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD ps aux | grep -v grep | grep datapipe-worker || exit 1

ENTRYPOINT ["/app/datapipe-worker"]
